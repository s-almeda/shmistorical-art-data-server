# Copy to .env and fill in. NEVER commit a real .env.

# Gates the admin SQL endpoints in index.py. Unset = those endpoints are disabled.
FINAL_SQL_ADMIN_PASSWORD=

# Gates the data-cleaner UI (templates/data_cleaner.py). Unset = disabled (fail closed).
STAGING_ADMIN_PASSWORD=

# Only needed if you run the data-build/scrape scripts against the Artsy API.
XAPP_TOKEN=

# Set automatically inside the container.
RUNNING_IN_DOCKER=true
